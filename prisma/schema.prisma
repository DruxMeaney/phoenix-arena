generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Users ────────────────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String?  @unique
  passwordHash  String?
  avatar        String?
  banner        String?  // profile banner/background image URL
  bio           String?  // short bio text
  socialTwitter String?
  socialYoutube String?
  socialTwitch  String?
  favoriteGame  String?
  favoriteWeapon String?
  motto         String?  // personal motto/tagline
  profileTheme  String   @default("neon-blue") // neon-blue, neon-red, neon-purple, ember
  region        String   @default("latam-norte")
  activisionId  String?
  platform      String   @default("uno")
  discordId     String?  @unique
  role          String   @default("player")
  status        String   @default("active")
  tier          String   @default("Detri")
  peakScore     Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  wallet             Wallet?
  createdChallenges  Match[]              @relation("MatchCreator")
  participations     MatchParticipant[]
  reportedResults    Result[]
  disputesAsReporter Dispute[]            @relation("DisputeReporter")
  disputesAsResolved Dispute[]            @relation("DisputeResolver")
  tournamentEntries  TournamentEntry[]
  matchRecords       RankingMatchRecord[]
  xp                 Int      @default(0)
  seasonXp           Int      @default(0)
  vaultItems         VaultItem[]
  feedEvents         FeedEvent[]
  purchases          Purchase[]
  profilePosts       ProfilePost[]
}

// ── Profile Posts (Player Blog/Feed) ─────────────────────────────
model ProfilePost {
  id          String   @id @default(cuid())
  userId      String
  content     String
  imageUrl    String?
  postType    String   @default("update") // update, achievement, highlight, setup
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

// ── Wallet ───────────────────────────────────────────────────────
model Wallet {
  id           String   @id @default(cuid())
  userId       String   @unique
  balance      Float    @default(0)
  heldBalance  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  walletId    String
  type        String
  amount      Float
  description String
  status      String   @default("completed")
  reference   String?
  createdAt   DateTime @default(now())

  wallet      Wallet   @relation(fields: [walletId], references: [id])
}

// ── Matches (Retos) ──────────────────────────────────────────────
model Match {
  id          String   @id @default(cuid())
  creatorId   String
  game        String   @default("Warzone")
  modalidad   String
  amount      Float
  rules       String
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator      User               @relation("MatchCreator", fields: [creatorId], references: [id])
  participants MatchParticipant[]
  result       Result?
  dispute      Dispute?
}

model MatchParticipant {
  id        String   @id @default(cuid())
  matchId   String
  userId    String
  team      Int      @default(1)
  joinedAt  DateTime @default(now())

  match     Match    @relation(fields: [matchId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([matchId, userId])
}

// ── Results ──────────────────────────────────────────────────────
model Result {
  id           String   @id @default(cuid())
  matchId      String   @unique
  reporterId   String
  winnerId     String?
  evidenceUrl  String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  match        Match    @relation(fields: [matchId], references: [id])
  reporter     User     @relation(fields: [reporterId], references: [id])
}

// ── Disputes ─────────────────────────────────────────────────────
model Dispute {
  id            String    @id @default(cuid())
  matchId       String    @unique
  reporterId    String
  resolverId    String?
  reason        String
  evidenceUrl   String?
  resolution    String?
  resolvedAt    DateTime?
  status        String    @default("open")
  createdAt     DateTime  @default(now())

  match         Match     @relation(fields: [matchId], references: [id])
  reporter      User      @relation("DisputeReporter", fields: [reporterId], references: [id])
  resolver      User?     @relation("DisputeResolver", fields: [resolverId], references: [id])
}

// ── Tournaments ──────────────────────────────────────────────────
model Tournament {
  id             String   @id @default(cuid())
  name           String
  game           String   @default("Warzone")
  format         String
  tournamentType String   @default("detri")
  entryFee       Float
  prizePool      Float    @default(0)
  maxSlots       Int
  filledSlots    Int      @default(0)
  status         String   @default("registration")
  startDate      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entries        TournamentEntry[]
}

model TournamentEntry {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  placement    Int?
  joinedAt     DateTime @default(now())

  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
}

// ── Ranking Records ──────────────────────────────────────────────
model RankingMatchRecord {
  id                         String   @id @default(cuid())
  playerId                   String
  tournamentType             String
  date                       DateTime @default(now())
  kills                      Int      @default(0)
  deaths                     Int      @default(0)
  position                   Int      @default(1)
  totalTeams                 Int      @default(1)
  teamKills                  Int      @default(0)
  teamPoints                 Float    @default(0)
  bestKillsInTournament      Int      @default(0)
  bestTeamPointsInTournament Float    @default(0)

  player                     User     @relation(fields: [playerId], references: [id])
}

// ── Pulse Feed (Activity Timeline) ───────────────────────────────
model FeedEvent {
  id          String   @id @default(cuid())
  userId      String?
  type        String   // match_win, match_loss, tournament_join, tournament_win, deposit, level_up, achievement, system
  title       String
  description String
  metadata    String?  // JSON string for extra data
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
}

// ── Phoenix Vault (Player Inventory) ─────────────────────────────
model VaultItem {
  id          String   @id @default(cuid())
  userId      String
  itemType    String   // credit_pack, name_change, record_reset, badge, title
  itemName    String
  quantity    Int      @default(1)
  used        Boolean  @default(false)
  usedAt      DateTime?
  acquiredAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

// ── Store Purchases ──────────────────────────────────────────────
model Purchase {
  id          String   @id @default(cuid())
  userId      String
  itemType    String
  itemName    String
  price       Float
  credits     Int      @default(0) // credits granted (for credit packs)
  status      String   @default("completed")
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

// ── Arena Ladder (Weekly XP Leaderboard) ─────────────────────────
model LadderSeason {
  id          String   @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("active") // active, finished
  prizePool   Float    @default(0)
  createdAt   DateTime @default(now())

  entries     LadderEntry[]
}

model LadderEntry {
  id          String   @id @default(cuid())
  seasonId    String
  userId      String
  xp          Int      @default(0)
  matchesPlayed Int    @default(0)
  wins        Int      @default(0)
  rank        Int?

  season      LadderSeason @relation(fields: [seasonId], references: [id])

  @@unique([seasonId, userId])
}
