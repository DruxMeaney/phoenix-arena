# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Call of Duty Stats API (Activision SSO)
COD_API_EMAIL=your_activision_email
COD_API_PASSWORD=your_activision_password

# PayPal. PAYPAL_WEBHOOK_ID is the id of the webhook subscription created
# in the PayPal dashboard (Apps & Credentials > your app > Webhooks).
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# MercadoPago (Mexico / MXN). The wallet stays in USD; the platform converts
# at preference creation using MXN_PER_USD. MERCADOPAGO_WEBHOOK_SECRET is
# the secret string from your webhook configuration in the MP dashboard.
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token
MERCADOPAGO_MODE=sandbox
MERCADOPAGO_WEBHOOK_SECRET=your_mercadopago_webhook_secret
MXN_PER_USD=18

# Stripe (USD native, no conversion). NOTE: Stripe restricts "skill-based
# gaming with cash prizes". The Stripe account must be approved for this
# category before going live — see https://stripe.com/restricted-businesses
# STRIPE_WEBHOOK_SECRET is the "Signing secret" from your webhook endpoint
# config in the Stripe dashboard.
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Wallet
# Commission rate retained from each withdrawal (0.05 = 5%).
WITHDRAWAL_COMMISSION=0.05

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
