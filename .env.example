# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Call of Duty Stats API (Activision SSO)
COD_API_EMAIL=your_activision_email
COD_API_PASSWORD=your_activision_password

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# MercadoPago (Mexico / MXN). The wallet stays in USD; the platform converts
# at preference creation using MXN_PER_USD.
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token
MERCADOPAGO_MODE=sandbox
MXN_PER_USD=18

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
